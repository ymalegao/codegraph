+++ b/include/rs/policy/eligibility_gate.h
@@ -0,0 +1,20 @@
+#pragma once
+
+#include "rs/config/scheduler_config.h"
+#include "rs/model/job.h"
+
+namespace rs::policy {
+
+class EligibilityGate {
+public:
+    EligibilityGate(const config::SchedulerConfig& config,
+                    bool has_interactive_job);
+
+    bool allow(const model::Job& job) const;
+
+private:
+    config::SchedulerConfig config_;
+    bool has_interactive_job_;
+};
+
+}  // namespace rs::policy
