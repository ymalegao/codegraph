diff --git a/src/policy/eligibility_gate.cpp b/src/policy/eligibility_gate.cpp
new file mode 100644
index 0000000..567c740
--- /dev/null
+++ b/src/policy/eligibility_gate.cpp
@@ -0,0 +1,18 @@
+#include "rs/policy/eligibility_gate.h"
+
+#include "rs/policy/eligibility_policy.h"
+
+namespace rs::policy {
+
+EligibilityGate::EligibilityGate(const config::SchedulerConfig& config,
+                                 bool has_interactive_job)
+    : config_(config), has_interactive_job_(has_interactive_job) {}
+
+bool EligibilityGate::allow(const model::Job& job) const {
+    (void)config_;
+    (void)has_interactive_job_;
+    // Remaining task: enforce the relocated background deferral rule here.
+    return is_eligible(job);
+}
+
+}  // namespace rs::policy
diff --git a/src/scheduler/plan_composer.cpp b/src/scheduler/plan_composer.cpp
index ebd96cd..3b21232 100644
--- a/src/scheduler/plan_composer.cpp
+++ b/src/scheduler/plan_composer.cpp
@@ -1,8 +1,9 @@
 #include "rs/scheduler/plan_composer.h"
 
 #include "rs/policy/batch_policy.h"
-#include "rs/util/append_if_eligible.h"
+#include "rs/policy/eligibility_gate.h"
 #include "rs/util/stable_order.h"
+#include "rs/util/vector_ops.h"
 
 namespace rs::scheduler {
 
@@ -11,8 +12,11 @@ model::FlushPlan PlanComposer::compose(
     const config::SchedulerConfig& config) const {
     std::vector<model::Job> eligible;
     eligible.reserve(jobs.size());
+    const policy::EligibilityGate gate(config, util::has_interactive_job(jobs));
     for (const auto& job : jobs) {
-        util::append_if_eligible(eligible, job);
+        if (gate.allow(job)) {
+            eligible.push_back(job);
+        }
     }
 
     util::stable_priority_sort(eligible);
